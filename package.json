{
    "name": "lint-rules",
    "type": "module",
    "version": "0.0.0",
    "private": true,
    "packageManager": "pnpm@10.15.1",
    "description": "All-in-one lint rules hub: ESLint + plugins, Stylelint, Biome, Oxlint, Oxfmt and other linters — searchable & categorized.",
    "author": "lonewolfyx <https://github.com/lonewolfyx>",
    "license": "MIT",
    "homepage": "https://github.com/lonewolfyx/lint-rules",
    "bugs": {
        "url": "https://github.com/lonewolfyx/lint-rules/issues"
    },
    "keywords": [
        "lint",
        "rules",
        "lint-hub",
        "all-in-one"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "prepare": "simple-git-hooks",
        "generate:eslint:rules": "oxnode ./scripts/generate-eslint-rules.ts",
        "generate:oxlint:rules": "oxnode ./scripts/generate-oxlint-rules.ts"
    },
    "devDependencies": {
        "@antfu/eslint-config": "catalog:",
        "@next/eslint-plugin-next": "catalog:",
        "@stylistic/eslint-plugin": "catalog:",
        "@tailwindcss/vite": "catalog:",
        "@types/node": "catalog:",
        "cheerio": "catalog:",
        "eslint": "catalog:",
        "eslint-config-auto": "catalog:",
        "eslint-config-prettier": "catalog:",
        "eslint-plugin-angular": "catalog:",
        "eslint-plugin-astro": "catalog:",
        "eslint-plugin-better-tailwindcss": "catalog:",
        "eslint-plugin-boundaries": "catalog:",
        "eslint-plugin-check-file": "catalog:",
        "eslint-plugin-eslint-comments": "catalog:",
        "eslint-plugin-functional": "catalog:",
        "eslint-plugin-html": "catalog:",
        "eslint-plugin-import": "catalog:",
        "eslint-plugin-import-access": "catalog:",
        "eslint-plugin-jest": "catalog:",
        "eslint-plugin-jsx-a11y": "catalog:",
        "eslint-plugin-n": "catalog:",
        "eslint-plugin-node": "catalog:",
        "eslint-plugin-perfectionist": "catalog:",
        "eslint-plugin-playwright": "catalog:",
        "eslint-plugin-prettier": "catalog:",
        "eslint-plugin-promise": "catalog:",
        "eslint-plugin-react": "catalog:",
        "eslint-plugin-react-hooks": "catalog:",
        "eslint-plugin-react-native": "catalog:",
        "eslint-plugin-react-perf": "catalog:",
        "eslint-plugin-security": "catalog:",
        "eslint-plugin-simple-import-sort": "catalog:",
        "eslint-plugin-svelte": "catalog:",
        "eslint-plugin-tailwindcss": "catalog:",
        "eslint-plugin-testing-library": "catalog:",
        "eslint-plugin-vitest": "catalog:",
        "giget": "catalog:",
        "lint-staged": "catalog:",
        "marked": "catalog:",
        "oxlint": "catalog:",
        "oxnode": "catalog:",
        "picocolors": "catalog:",
        "rimraf": "catalog:",
        "simple-git-hooks": "catalog:",
        "svelte": "catalog:",
        "tinyexec": "catalog:",
        "turbo": "catalog:",
        "typescript": "catalog:"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "lint-staged": {
        "*": "eslint --fix"
    }
}
